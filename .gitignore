# .idea folder (Rider's project files)
.idea/

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider's workspace and UI state files
.idea/*/
!.idea/workspace.xml
!.idea/tasks.xml
!.idea/dictionaries
!.idea/vcs.xml
!.idea/modules.xml

# Logs
.idea/*.log
*.log

# Build artifacts
bin/
obj/
out/

# Dependency caches
*.pdb
*.mdb
*.ilk
*.meta
*.cache
*.dll
*.exe

# Rider run/debug configurations
.idea/runConfigurations/

# Temporary files
*.tmp
*.temp

# Rider-specific settings
.idea/codeStyles/
.idea/libraries/
.idea/modules/
.idea/uiDesigner.xml

# OS-specific files
.DS_Store
Thumbs.db

# Exclude Rider plugins
.idea/plugins/

# .NET Core-specific
project.lock.json
project.fragment.lock.json
artifacts/

# Azure build artifacts
*.azurefunctions/

# NuGet packages
*.nupkg
*.snupkg
.nuget/packages/
.nuget/v3-cache/

# Rider's local history
.idea/localHistory/

# Rider's workspace XML
.idea/workspace.xml

# Rider's gradle files (if used in plugins)
.idea/gradle.xml
.idea/gradle-jvm.xml
