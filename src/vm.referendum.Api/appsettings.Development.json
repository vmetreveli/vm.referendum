{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=5432;Database=postgres;User Id=admin;Password=admin1234;"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": "Debug",
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "Columns": {
    "message": "RenderedMessageColumnWriter",
    "level": {
      "Name": "LevelColumnWriter",
      "Args": {
        "renderAsText": true,
        "dbType": "Varchar"
      }
    },
    "raise_date": "TimestampColumnWriter",
    "exception": "ExceptionColumnWriter"
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "Referendum",
    "Audience": "referendum.ge",
    "SecurityKey": "secret-key-that-also-needs-to-be-at-least-16-characters-long",
    "TokenExpirationInMinutes": 60
  },
  "EmailConfiguration": {
    "Port": "465",
    "Host": "smtp.gmail.com",
    "Password": "ryjk kkxr sahc uugn",
    "From": "referendumgeo@gmail.com"
  },
  "Outbox": {
    "IntervalInSeconds": 10,
    "BatchSize": 10
  },
  "AppConfiguration": {
    "RabbitMQ": {
      "Host": "127.0.0.1",
      "VirtualHost": "dev",
      "Username": "guest",
      "Password": "guest"
    },
    "Quartz": {
      "OutboxJob": "0/3 * * * * ?"
    }
  }
