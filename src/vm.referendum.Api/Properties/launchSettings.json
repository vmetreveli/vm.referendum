{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:13908",
      "sslPort": 44319
    }
  },
  "profiles": {
    "Referendum.Api_Dev": {
      "commandName": "Project",
      "launchUrl": "swagger",
      "applicationUrl": "http://localhost:8181",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "Referendum.Api_Dev_Local": {
      "commandName": "Project",
      "launchUrl": "swagger",
      "applicationUrl": "http://localhost:8181",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Local"
      }
    },
    "Referendum.Api_Dev_Debug": {
      "commandName": "Project",
      "launchUrl": "swagger",
      "applicationUrl": "http://localhost:8181",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "Referendum.Api_Release": {
      "commandName": "Project",
      "launchUrl": "swagger",
      "applicationUrl": "http://localhost:8181",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Release"
      }
    },
    "Docker": {
      "commandName": "Docker",
      "launchUrl": "swagger",
      "applicationUrl": "{Scheme}://{ServiceHost}:{ServicePort}/swagger",
      "publishAllPorts": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  }
}