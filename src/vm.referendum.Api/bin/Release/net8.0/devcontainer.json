{
  "name": "Referendum Clean Architecture Dev Container",
  "build": {
    "dockerfile": "Dockerfile", // Refer to the Dockerfile you provided
    "context": ".",
    "args": {
      "VARIANT": "8.0" // Set .NET SDK version to match your Dockerfile (.NET 8.0)
    }
  },
  "extensions": [
    "ms-dotnettools.csharp", // C# extension for .NET development
    "eamodio.gitlens", // GitLens for Git history and blame annotations
    "ms-azuretools.vscode-docker", // Docker extension for managing containers
    "streetsidesoftware.code-spell-checker", // Code spell checker
    "editorconfig.editorconfig", // EditorConfig for coding style
    "esbenp.prettier-vscode" // Prettier for consistent code formatting
  ],
  "settings": {
    "terminal.integrated.defaultProfile.linux": "bash", // Use bash for terminal
    "editor.formatOnSave": true, // Format code on save
    "dotnet.testOptions": {
      "autoTestMode": "watch" // Automatically run tests when code changes
    }
  },
  "postCreateCommand": "dotnet restore && dotnet build", // Restore and build the project after the container is created
  "remoteUser": "vscode", // Use the vscode user for running the container
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:1": { // Docker in Docker
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/dotnet:1": { // .NET SDK feature
      "version": "8.0" // Use .NET 8.0 SDK to match your project
    }
  },
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind" // Mount local project folder
  ],
  "ports": [
    "80:80", // Map HTTP port for debugging API
    "443:443" // Map HTTPS port for debugging API
  ],
  "customizations": {
    "jetbrains": {
      "settings": {
        "com.intellij:app:HttpConfigurable.use_proxy_pac": true,
        "Docker:app:DockerSettings.dockerComposePath": "/usr/local/bin/docker",
        "Docker:app:DockerSettings.dockerPath": "/usr/local/bin/docker",
        "Git4Idea:app:Git-Application-Settings.use_credential_helper": true
      }
    }
  }
}
