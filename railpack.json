{
  "$schema": "https://schema.railpack.com",
  "providers": {
    "dotnet": {
      "version": "10.0"
    }
  },
  "steps": {
    "build": {
      "commands": [
        "dotnet --info",
        "dotnet publish src/vm.referendum.Api/vm.referendum.Api.csproj -c Release -o out"
      ]
    }
  },
  "deploy": {
    "startCommand": "dotnet out/vm.referendum.Api.dll"
  }
}